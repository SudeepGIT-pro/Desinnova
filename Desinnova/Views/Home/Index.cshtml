@model Desinnova.Models.HomeViewModel
@{
    ViewData["Title"] = "Home Page";
}

<div class="container mt-4">
    <div class="text-center mb-5">
        <h1 class="display-4">Welcome to Desinnova</h1>
        <p class="lead">Holiday Schedule & Staff Availability for 2026</p>
    </div>

    <!-- Holiday List Section -->
    <div class="mb-5">
        <h2 class="mb-3">
            <i class="bi bi-calendar-event"></i> Holiday List
        </h2>
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>S. No</th>
                        <th>Name of the Holiday</th>
                        <th>Date</th>
                        <th>Day</th>
                        <th>Location</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var holiday in Model.Holidays)
                    {
                        <tr>
                            <td>@holiday.SerialNo</td>
                            <td>@holiday.Name</td>
                            <td>@holiday.Date.ToString("dd/MM/yyyy")</td>
                            <td>@holiday.Day</td>
                            <td>@holiday.Location</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Staff Availability Section -->
    <div class="mb-5">
        <h2 class="mb-3">
            <i class="bi bi-people-fill"></i> Staff Availability Section
        </h2>
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Sl. No</th>
                        <th>Staff Name</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                        <th>Location</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var staff in Model.StaffList)
                    {
                        <tr>
                            <td>@staff.SerialNo</td>
                            <td>@staff.Name</td>
                            <td>@staff.StartDate.ToString("dd/MM/yyyy")</td>
                            <td>@(staff.EndDate?.ToString("dd/MM/yyyy") ?? "-")</td>
                            <td>@staff.Location</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>